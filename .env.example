# Geoapify API key (for server-side routing distance calculation)
GEOAPIFY_API_KEY=your_geoapify_key_here

# Session secret (generate a random 32+ character string)
SESSION_SECRET=change_this_to_a_random_string

# Admin credentials (app will hash the password on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# Driver credentials (separate from admin)
DRIVER_USERNAME=driver
DRIVER_PASSWORD=change_this_to_a_strong_password

# Stripe API key (use restricted key from dashboard)
STRIPE_SECRET_KEY=your_stripe_restricted_key_here

# Email SMTP settings (for driver acceptance/rejection emails)
# Leave blank to log emails to console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@vsdsynergy.co.uk

# Server port
PORT=3000
